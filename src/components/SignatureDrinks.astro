---
const drinks = [
  {
    name: 'Flat White',
    subtitle: 'microfoam catifelat',
    detail:
      'Shot ristretto dublu, lapte integral aburit la 58°C, turnat într-o ceașcă grea. Referința casei.',
    price: '10 LEI',
    origin: 'Origine · Brazilia / Ethiopia',
    image: 'https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?auto=format&fit=crop&w=800&q=80',
  },
  {
    name: 'V60',
    subtitle: 'claritate într-o ceașcă',
    detail:
      'Turnată în spirale de mână peste filtru de hârtie, pentru o ceașcă curată, ca un ceai fin, care-ți spune exact de unde vine.',
    price: '12 LEI',
    origin: 'Origine · Colombia Huila',
    image: 'https://images.unsplash.com/photo-1497935586351-b67a49e012bf?auto=format&fit=crop&w=800&q=80',
  },
  {
    name: 'Cappuccino',
    subtitle: 'echilibru perfect',
    detail:
      'Un shot de espresso proaspăt, îmbrățișat de lapte cremos, texturat la perfecție. Simplu, clasic, aromat.',
    price: '8 LEI',
    origin: 'Blend · rețeta casei',
    image: 'https://images.unsplash.com/photo-1511920170033-f8396924c348?auto=format&fit=crop&w=800&q=80',
  },
  {
    name: 'Ice Latte',
    subtitle: 'răcoritor și intens',
    detail:
      'Espresso extras lent, turnat peste gheață și lapte rece. Perfect pentru zilele călduroase de vară.',
    price: '12 LEI',
    origin: 'Blend · rețeta casei',
    image: 'https://images.unsplash.com/photo-1461023058943-07fcbe16d735?auto=format&fit=crop&w=800&q=80',
  },
];
---

<section class="drinks frame" id="signature">
  <div class="drinks-head" data-reveal-stagger>
    <p class="eyebrow" data-reveal-child>La bar, azi</p>
    <h2 class="display" data-reveal-child>Cești de semnătură,<br/> servite cu <em>intenție.</em></h2>
    <p class="lead" data-reveal-child>
      Patru turnări la care ne tot întoarcem. Comandă una în orb - îți spunem
      originea, extracția și de ce tocmai lotul ăsta a prins săptămâna asta.
    </p>
  </div>

  <div class="drinks-grid">
    {drinks.map((d, i) => (
      <article class="drink-card" data-reveal-child data-tilt style={`--i:${i}`}>
        <div class="drink-image">
          <img src={d.image} alt={d.name} loading="lazy" />
          <span class="drink-price-pill">{d.price}</span>
        </div>
        <div class="drink-body">
          <div class="drink-index">{String(i + 1).padStart(2, '0')}</div>
          <header>
            <h3>{d.name}</h3>
            <p class="hand">{d.subtitle}</p>
          </header>
          <p class="drink-detail">{d.detail}</p>
          <footer>
            <span class="origin">{d.origin}</span>
          </footer>
        </div>

        <svg class="leaf-deco" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M50 10 C 70 30 90 50 50 90 C 10 50 30 30 50 10 Z"
                fill="none" stroke="currentColor" stroke-width="1"/>
          <path d="M50 10 L 50 90" fill="none" stroke="currentColor" stroke-width="1"/>
        </svg>
      </article>
    ))}
  </div>

  <div class="drinks-foot" data-reveal="fade">
    <a href="/menu" class="btn-leaf">
      Vezi tot meniul
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .drinks {
    position: relative;
    z-index: 2;
    padding-block: clamp(4rem, 10vw, 8rem);
    width: min(1280px, 100%);
    margin: 0 auto;
  }
  .drinks-head {
    display: grid;
    gap: 1rem;
    max-width: 620px;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .drinks-head .display {
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    color: var(--moss-deep);
    margin: 0;
  }
  .drinks-head em { color: var(--ember); }
  .lead {
    color: var(--text-body);
    font-weight: 600;
    max-width: 52ch;
  }

  .drinks-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 960px) { .drinks-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .drinks-grid { grid-template-columns: 1fr; } }

  .drink-card {
    position: relative;
    border: 1px solid rgba(66, 81, 53, .2);
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(251, 247, 236, .9), rgba(237, 227, 204, .65));
    backdrop-filter: blur(6px);
    overflow: hidden;
    transition: box-shadow .5s, border-color .5s;
    display: grid;
    grid-template-rows: auto 1fr;
    box-shadow: 0 18px 40px -24px rgba(43, 52, 37, .35);
  }
  .drink-card:hover {
    border-color: rgba(184, 80, 46, .5);
    box-shadow: 0 30px 55px -20px rgba(43, 52, 37, .35), 0 0 0 1px rgba(184, 80, 46, .15);
  }

  .drink-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .drink-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(.2,.7,.2,1), filter .6s;
    filter: saturate(1.02) contrast(1.02);
  }
  .drink-card:hover .drink-image img {
    transform: scale(1.06);
    filter: saturate(1.08) contrast(1.05);
  }
  .drink-price-pill {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: .35rem .8rem;
    border-radius: 999px;
    background: var(--ember);
    color: var(--parchment-soft);
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: .92rem;
    letter-spacing: .02em;
    z-index: 2;
    box-shadow: 0 8px 20px -8px rgba(138, 58, 30, .55);
  }

  .drink-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: .65rem;
  }

  .drink-index {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: .7rem;
    letter-spacing: .3em;
    color: var(--ember-deep);
  }

  .drink-card h3 {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 1.7rem;
    color: var(--moss-deep);
    margin: 0;
    line-height: 1;
  }
  .drink-card .hand { color: var(--ember); font-size: 1.3rem; margin: .2rem 0 0; }

  .drink-detail {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-body);
    margin: 0;
  }

  .drink-card footer {
    display: flex;
    justify-content: flex-end;
    align-items: baseline;
    padding-top: .8rem;
    border-top: 1px dashed rgba(66, 81, 53, .25);
  }
  .origin {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: .68rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--moss);
  }

  .leaf-deco {
    position: absolute;
    top: -25px;
    right: -30px;
    width: 140px;
    height: 140px;
    color: rgba(66, 81, 53, .12);
    transition: transform .6s cubic-bezier(.2,.7,.2,1), color .4s;
    pointer-events: none;
    z-index: 1;
  }
  .drink-card:hover .leaf-deco { color: rgba(184, 80, 46, .25); transform: rotate(18deg) scale(1.1); }

  .drinks-foot {
    margin-top: clamp(2rem, 5vw, 3.5rem);
    display: flex;
    justify-content: center;
  }
</style>
