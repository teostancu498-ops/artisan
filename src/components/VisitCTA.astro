---
import { site } from '~/data/site';

const visitImage = '/images/interior-bar.webp';
---

<section class="visit-cta frame" id="visit">
  <div class="visit-inner">
    <div class="visit-copy" data-reveal-stagger>
      <p class="eyebrow" data-reveal-child>Treci pe la noi</p>
      <h2 class="display" data-reveal-child>
        Ceainicul e <em>deja pe foc.</em>
      </h2>
      <p class="lead" data-reveal-child>
        Suntem la 2 minute de centrul Piteștiului. Fără rezervări, fără grabă —
        doar un scaun la bar, un loc la geam dacă ai noroc și un barista care
        are, probabil, un disc nou pus.
      </p>

      <div class="visit-facts" data-reveal-child>
        <div>
          <p class="hand">ne găsești la</p>
          <p class="fact">{site.address}<br/>{site.postal}, {site.city}</p>
        </div>
        <div>
          <p class="hand">deschis azi</p>
          <p class="fact">08:00 – 21:00</p>
        </div>
      </div>

      <div class="visit-ctas" data-reveal-child>
        <a href={site.directionsUrl} target="_blank" rel="noopener" class="btn-leaf">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2C7 2 3 6 3 11c0 6 9 11 9 11s9-5 9-11c0-5-4-9-9-9z"
                  stroke="currentColor" stroke-width="1.5"/>
            <circle cx="12" cy="11" r="3" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          Indicații
        </a>
        <a href="/visit-us" class="btn-ghost">
          Program, parcare & ore liniștite
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="visit-map" data-reveal="scale">
      <div class="mood-image map-frame" data-parallax=".1">
        <img src={visitImage} alt="Cafenea caldă cu plante" loading="lazy" />
        <div class="map-pin" aria-hidden="true">
          <div class="pin-pulse"></div>
          <div class="pin-dot"></div>
          <span class="pin-label">Artizan Urban</span>
        </div>
      </div>
      <p class="map-caption hand">Bulevardul I. C. Brătianu, bl. 35 — ușa verde.</p>
    </div>
  </div>
</section>

<style>
  .visit-cta {
    position: relative;
    z-index: 2;
    padding-block: clamp(5rem, 10vw, 9rem);
  }
  .visit-inner {
    width: min(1200px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
  }
  @media (max-width: 900px) {
    .visit-inner { grid-template-columns: 1fr; }
  }

  .visit-copy .display {
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    color: var(--moss-deep);
    margin: .8rem 0 1.4rem;
  }
  .visit-copy em { color: var(--ember); }
  .visit-copy .lead {
    color: var(--text-body);
    font-weight: 600;
    max-width: 52ch;
    margin-bottom: 2rem;
  }

  .visit-facts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 520px) {
    .visit-facts { grid-template-columns: 1fr; }
  }
  .visit-facts .hand { font-size: 1.2rem; color: var(--ember); margin-bottom: .2rem; }
  .visit-facts .fact {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 1.15rem;
    color: var(--moss-deep); margin: 0;
  }

  .visit-ctas {
    display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center;
  }

  .visit-map .map-frame {
    aspect-ratio: 1 / 1;
  }
  .visit-map .map-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .map-pin {
    position: absolute;
    top: 45%;
    left: 55%;
    transform: translate(-50%, -50%);
    z-index: 4;
    display: grid;
    place-items: center;
    pointer-events: none;
  }
  .pin-pulse, .pin-dot {
    grid-area: 1 / 1;
    border-radius: 999px;
  }
  .pin-pulse {
    width: 56px; height: 56px;
    background: rgba(184, 80, 46, .3);
    animation: mapPinPulse 2s ease-out infinite;
  }
  .pin-dot {
    width: 18px; height: 18px;
    background: var(--ember);
    box-shadow: 0 0 0 3px var(--parchment-soft), 0 0 16px rgba(184, 80, 46, .5);
  }
  .pin-label {
    position: absolute;
    top: -40px;
    left: 50%;
    transform: translateX(-50%);
    padding: .35rem .8rem;
    border-radius: 999px;
    background: var(--moss-deep);
    color: var(--candle);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: .65rem;
    letter-spacing: .28em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  @keyframes mapPinPulse {
    0% { transform: scale(.6); opacity: .9; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  .map-caption {
    text-align: right;
    margin-top: 1rem;
    font-size: 1.25rem;
    color: var(--moss);
  }
</style>
