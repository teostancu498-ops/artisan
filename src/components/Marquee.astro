---
const items: string[] = (Astro.props.items as string[]) ?? [
  'Cafea fără grabă',
  'Turnată de mână',
  'Origini de specialitate',
  'Liniștea serei',
  'Ceai din fereastra cu plante',
  'În Pitești, de la început',
];
const doubled = [...items, ...items];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {doubled.map((text) => (
      <span class="marquee-item">
        <span class="leaf" aria-hidden="true">✦</span>
        {text}
      </span>
    ))}
  </div>
</div>

<style>
  .marquee {
    overflow: hidden;
    padding-block: 1.3rem;
    border-block: 1px solid rgba(66, 81, 53, .2);
    background: linear-gradient(180deg, rgba(251, 247, 236, .5), rgba(237, 227, 204, .45));
    position: relative;
  }
  .marquee::before, .marquee::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 100px;
    pointer-events: none;
    z-index: 2;
  }
  .marquee::before { left: 0; background: linear-gradient(90deg, var(--parchment-soft), transparent); }
  .marquee::after  { right: 0; background: linear-gradient(-90deg, var(--parchment-soft), transparent); }
  .marquee-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    will-change: transform;
  }
  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    color: var(--moss-deep);
    white-space: nowrap;
    transition: color .3s;
  }
  .marquee-item:hover { color: var(--ember-deep); }
  .leaf { color: var(--ember); font-style: normal; font-size: .8em; }
</style>
