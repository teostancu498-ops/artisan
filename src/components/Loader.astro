---
---
<div id="loader" class="loader-leaf" aria-hidden="true">
  <div class="loader-mark">
    <svg viewBox="0 0 60 60" width="56" height="56" aria-hidden="true">
      <path
        d="M30 56c-12 0-22-9-22-23 0-8 6-14 14-14 3 0 6 1 8 3 2-2 5-3 8-3 8 0 14 6 14 14 0 14-10 23-22 23z"
        fill="none" stroke="currentColor" stroke-width="1.2"
      />
      <path d="M30 56c0-12 3-22 10-29M30 56c0-12-3-22-10-29"
        fill="none" stroke="currentColor" stroke-width="1.2" />
      <circle cx="30" cy="12" r="2.4" fill="currentColor" />
    </svg>
      <p>Artizan Urban</p>
      <span class="loader-hint">se pregătește cafeaua…</span>
  </div>

  <style>
    .loader-mark {
      display: grid;
      place-items: center;
      gap: 1rem;
      color: var(--candle);
      opacity: .9;
    }
    .loader-mark svg { animation: breathe 2.2s ease-in-out infinite; }
    .loader-mark p {
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      letter-spacing: .5em;
      text-transform: uppercase;
      font-size: .7rem;
      opacity: .9;
      color: var(--candle);
    }
    .loader-hint {
      font-family: 'Caveat', cursive;
      font-size: 1.2rem;
      color: var(--ember-glow);
      opacity: .8;
      margin-top: -.4rem;
    }
    @keyframes breathe {
      0%,100% { transform: scale(1); opacity: .9; }
      50%     { transform: scale(1.05); opacity: 1; }
    }
  </style>
</div>
